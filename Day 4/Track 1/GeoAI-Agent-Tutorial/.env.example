# ── LLM ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key

# ── Dataset APIs ────────────────────────────────────────────────────────────
# Free key from https://firms.modaps.eosdis.nasa.gov/api/
FIRMS_MAP_KEY=your-firms-map-key

# ── NASA Earthdata (HLS + DSWx downloads) ──────────────────────────────────
# Register at https://urs.earthdata.nasa.gov/
EARTHDATA_LOGIN=your-earthdata-username
EARTHDATA_PASSWORD=your-earthdata-password

# ── Prithvi inference (SageMaker Async endpoint) ───────────────────────────
# Set by the workshop organiser after running sagemaker/deploy.ipynb
AWS_REGION=us-east-1
SAGEMAKER_ENDPOINT_NAME=prithvi-workshop
SAGEMAKER_ASYNC_BUCKET=your-s3-bucket-name
