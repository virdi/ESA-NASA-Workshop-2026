# ── LLM ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key

# ── Dataset APIs ────────────────────────────────────────────────────────────
# Free key from https://firms.modaps.eosdis.nasa.gov/api/
FIRMS_MAP_KEY=your-firms-map-key

# ── NASA Earthdata (HLS + DSWx downloads) ──────────────────────────────────
# Register at https://urs.earthdata.nasa.gov/
EARTHDATA_LOGIN=your-earthdata-username
EARTHDATA_PASSWORD=your-earthdata-password

# ── Prithvi inference server ────────────────────────────────────────────────
# URL of the remote Prithvi inference server (provided by workshop organizers).
PRITHVI_SERVER_URL=http://localhost:8000
